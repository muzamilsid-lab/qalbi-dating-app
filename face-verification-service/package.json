{
  "name": "face-verification-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":    "ts-node-dev --respawn --transpile-only src/server.ts",
    "build":  "tsc --project tsconfig.json",
    "start":  "node dist/server.js",
    "db:migrate": "psql $DATABASE_URL -f src/db/schema.sql"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.540.0",
    "cors":    "^2.8.5",
    "dotenv":  "^16.4.5",
    "express": "^4.18.3",
    "helmet":  "^7.1.0",
    "pg":      "^8.11.3",
    "zod":     "^3.22.4"
  },
  "devDependencies": {
    "@types/cors":    "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node":    "^20.11.5",
    "@types/pg":      "^8.11.2",
    "ts-node-dev":    "^2.0.0",
    "typescript":     "^5.3.3"
  }
}
